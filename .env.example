# aqua-matrix-agent — instance configuration template.
#
# Copy this to a real `.env` (which is gitignored — never commit real values)
# and fill in your own target. Each agent INSTANCE gets its own file:
#
#   cp .env.example .env                 # for the one-shot CLI / dev use
#   # …or, per long-running daemon, point AGENT_ENV_FILE at a dedicated file:
#   #   AGENT_ENV_FILE=~/.aqua-matrix-claude-channel/agent.env
#
# Loaded at startup before flags are parsed. Precedence (high → low):
#   explicit CLI flag  >  process env (e.g. systemd Environment=)  >  .env  >  built-in default
# So anything set here is overridable by a flag or a real environment variable.

# REQUIRED for the daemons (and for the CLI's --message/--read): the Matrix user
# ID this instance talks to. No default ships in the binary — set your own.
# Example shape only (replace with a real MXID you control):
AGENT_TARGET=@you:matrix.example.com

# Homeserver + OIDC provider. Defaults shown; override only for a different
# deployment. These are the built-in defaults, listed here for discoverability.
# MATRIX_URL=https://matrix.inblock.io
# SIWX_URL=https://siwx-oidc.inblock.io

# Identity / storage. Defaults are per-binary (agent.pem / heartbeat.pem /
# claude-channel.pem) and ~/.aqua-matrix-<role>. Override per instance:
# AGENT_KEY_FILE=agent.pem
# AGENT_STORE_DIR=~/.aqua-matrix-agent

# OIDC client is auto-registered on first run; set these only to pin an existing
# client (see {store_dir}/config.toml for the cached, auto-registered values).
# OIDC_CLIENT_ID=
# OIDC_REDIRECT_URI=http://localhost:0/callback
