target/
# Persistent per-identity crypto stores for the e2e tests (device keys; machine-local).
.e2e-store/
*.pem
*.db
*.db-wal
*.db-shm
.env
.env.*
# …but DO track the committed template (real values live only in local .env).
!.env.example
.claude/*
!.claude/skills/

# Real typed-instance bindings hold a live AGENT_TARGET — gitignore them, the
# same way real `.env` is ignored. Only the `*.example` template is tracked.
instances/*.toml
!instances/*.toml.example
