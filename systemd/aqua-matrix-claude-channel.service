[Unit]
Description=Aqua Matrix claude-channel (LLM bridge — DM in, `claude -p` reply out)
Documentation=https://github.com/inblockio/aqua-matrix-hello
After=network-online.target
Wants=network-online.target
# Crash-loop guard belongs in [Unit] in modern systemd; [Service] placement
# is silently ignored.
StartLimitIntervalSec=300
StartLimitBurst=10

[Service]
Type=simple
WorkingDirectory=%h/aqua-matrix-hello
# Forward CONTEXT_WINDOW for consistency with the heartbeat (status payloads
# only matter on the heartbeat side, but keep envs aligned).
Environment=CONTEXT_WINDOW=1000000
# claude is at ~/.local/bin/claude; the daemon also resolves this dynamically
# but setting PATH lets a future PATH-based claude lookup work too.
Environment=PATH=%h/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
# Per-instance config (AGENT_TARGET, optional MATRIX_URL/SIWX_URL overrides):
# the daemon loads this `.env` at startup. This file is machine-local and NOT in
# the repo — copy `.env.example` and fill in your own target. Multi-agent: each
# instance points AGENT_ENV_FILE at its own file.
Environment=AGENT_ENV_FILE=%h/.aqua-matrix-claude-channel/agent.env
# Reference example backend (was `aqua-matrix-agent --claude-channel` before
# the workspace split). The unit name stays `aqua-matrix-claude-channel` so
# `#shell respawn-channel`, the registry role, and skills are unaffected.
ExecStart=%h/aqua-matrix-hello/target/debug/aqua-matrix-claude-p --key-file claude-channel.pem --store-dir %h/.aqua-matrix-claude-channel
Restart=always
RestartSec=5s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
