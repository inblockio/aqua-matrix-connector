{
  "name": "claude-channel",
  "version": "0.1.0",
  "description": "Matrix LLM channel agent: forwards inbound DMs from its AGENT_TARGET through `claude -p`, replies with the result. One container = one identity (self-minted DID), persistent for the container's life; replace the container to get a fresh identity + memory.",
  "image": "aqua-matrix-agent:poc",
  "role": "claude-channel",
  "display_name": "claude-channel",
  "hello": "Hello {user_id} — I am a claude-channel agent (DID {did}). DM me and I will run it through claude -p and reply.",
  "contract": {
    "allowed_tools": [
      "Read",
      "Glob",
      "Grep",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(rg:*)"
    ],
    "permissions": {
      "allow": [
        "Read",
        "Glob",
        "Grep",
        "Bash(ls:*)",
        "Bash(cat:*)",
        "Bash(rg:*)"
      ],
      "deny": [
        "Bash(rm:*)",
        "Bash(sudo:*)",
        "Bash(curl:*)",
        "Bash(wget:*)",
        "Bash(git push:*)",
        "Write",
        "Edit"
      ]
    }
  },
  "memory": {
    "config_dir": "/agent/memory",
    "log_transcripts": true
  },
  "ref_mounts": [
    {
      "host_path": "../aqua-rs-sdk",
      "container_path": "/refs/aqua-rs-sdk",
      "read_only": true
    },
    {
      "host_path": "../aqua-spec",
      "container_path": "/refs/aqua-spec",
      "read_only": true
    }
  ],
  "resources": {
    "memory_mb": 2048,
    "cpus": 2.0,
    "pids_limit": 512
  },
  "auth": {
    "method": "subscription_oauth_token",
    "env_var": "CLAUDE_CODE_OAUTH_TOKEN"
  }
}
